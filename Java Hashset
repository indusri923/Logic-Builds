import java.io.*;
import java.util.*;
import java.util.AbstractMap.SimpleEntry;

public class Solution {

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int t = sc.nextInt();

        Set<SimpleEntry<String, String>> set = new HashSet<>();

        for (int i = 0; i < t; i++) {
            String a = sc.next();
            String b = sc.next();

            set.add(new SimpleEntry<>(a, b));
            System.out.println(set.size());
        }
    }
}
